#include <stdio.h>

int main(){
    int a[4][4], b[4][4], m[4][4];
    for (int i=0; i<4; i++){
        for(int j=0; j<4; j++){
            printf ("digite um valor para a matriz A: ");
            scanf ("%d", &a[i][j]);
        }
    }

    for (int i=0; i<4; i++){
        for (int j=0; j<4; j++){
             printf ("digite um valor para a matriz B: ");
             scanf ("%d", &b[i][j]);
        }
    }

    for (int i=0; i<4; i++){
        for (int j=0; j<4; j++){
            if (a[i][j] >= b[i][j]){
               m[i][j] = a[i][j];
            }
            if (b[i][j] > a[i][j]){
               m[i][j] = b[i][j];
            }
        }
    }

   printf ("matriz com maiores valores:\n");
   for (int i=0; i<4; i++){
       for (int j=0; j<4; j++){
           printf ("%d\t", m[i][j]);
       }
       printf ("\n");
   }
}
