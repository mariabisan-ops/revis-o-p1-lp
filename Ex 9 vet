#include <stdio.h>

int main (){
    int v[6];
    for (int i=0; i<6; i++){
        printf ("digite um valor:");
        scanf ("%d", &v[i]);
        while (v[i]%2 != 0){
           printf ("valor invalido.\nDigite novamente:");
           scanf ("%d", &v[i]);
        }
    }
    printf ("valores do vetor em ordem inversa:");
    for (int i=5; i>=0; i--){
        printf ("\n%d", v[i]);
    }
}
