#include <stdio.h>

int main () {
    int v[5], menor, maior, pos1, pos2;
    for (int i=0; i<5; i++){
        printf ("digite um valor: ");
        scanf ("%d", &v[i]);
    }
    menor = v[0];
    pos1 = 0;
    maior = v[0];
    pos2 = 0;
    for (int i =0; i<5; i++){
        if (v[i] <menor){
           menor = v[i];
