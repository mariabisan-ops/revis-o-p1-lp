#include <stdio.h>

int main (){
    int m[3][3], soma=0;
    for (int i =0; i<3; i++){
        for (int j=0; j<3; j++){
            printf ("digite um valor: ");
            scanf ("%d", &m[i][j]);
        }
    }

    for (int i=1; i<3; i++){
        for (int j=0; j<3; j++){
            if (j<i){
               soma= soma + m[i][j];
            }
        }
    }
    printf ("a soma dos valores abaixo da principal é: %d", soma);
}
