#include <stdio.h>

int main(){
    int v[10], m[10], cont=0, x;
    for (int i = 0; i<10; i++){
        printf ("digite um valor: ");
        scanf ("%d", &v[i]);
    }
    printf ("digite o valor de x: ");
    scanf ("%d", &x);
    for (int i=0; i<10; i++){
        if (v[i]%x == 0){
           m[cont] = v[i];
           cont ++;
        }
    }
    printf ("vetor de multiplos: ");
    for (int i =0; i<10; i++){
        printf ("\n%d", m[i]);
    }
    
}
