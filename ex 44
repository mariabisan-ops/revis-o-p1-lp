#include <stdio.h>

int main (){
    float n1, n2;
    printf ("digite o primeiro valor:\n");
    scanf ("%f", &n1);
    printf ("digite o segundo valor:\n");
    scanf ("%f", &n2);
    while (n2==0){
        printf ("valor inválido.\nDigite novamente:\n");
        scanf ("%f", &n2);
    }
    printf ("resultado final: %.2f", n1/n2);
}
