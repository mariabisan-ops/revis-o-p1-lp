#include <stdio.h>

int main(){
    float n1, n2, media;
    printf ("digite a nota da primeira avaliação:\n");
    scanf ("%f", &n1);
    while (n1<0 || n1>10){
        printf ("Valor invalido.\nDigite novamente:\n");
        scanf ("%f", &n1);
    }
    printf ("digite a nota da segunda avaliação:\n");
    scanf ("%f", &n2);
    while (n2<0 || n2>10){
        printf ("Valor invalido.\nDigite novamente:\n");
        scanf ("%f", &n2);
    }
    media = (n1+n2)/2;
    printf ("media do aluno: %.2f", media);
}
