#include <stdio.h>

int main (){
  int v[20], n[20], cont1=0, cont2=0;
  for (int i=0; i<20; i++){
    printf ("digite um valor: ");
    scanf("%d", &v[i]);
  }
  for (int i=0; i<20; i++){
    for (int j=i+1; j<20; j++){
      if (v[i]==v[j] && i!=j){
        cont1++;
      }
    }
    if (cont1==0){
       n[cont2] = v[i];
       cont2++;
    }
 }
 printf ("vetor sem repetidos:\n ");
 for (int i=0; i<cont2; i++){
    printf("%d\t", n[i]);
 }
  }
