#include <stdio.h>

int main (){
  int m[3][3], soma =0;
  for (int i=0; i<3; i++){
    for (int j=0; j<3; j++){
      printf ("digite um valor: ");
      scanf ("%d", &m[i][j]);
    }
  }

  for (int i=0; i<3; i++){
    for (int j=0; j<3; j++){
      if (j+i==2){
        soma = soma + m[i][j];
      }
    }
  }
  printf ("a soma da diagonal secundaria eh: %d", soma);
}
