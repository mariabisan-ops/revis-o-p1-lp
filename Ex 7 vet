#include <stdio.h>

int main (){
    int v[10], maior, pos;
    for (int i=0; i<10; i++){
        printf ("digite um valor:");
        scanf ("%d", &v[i]);
    }
    maior = v[0];
    pos = 0;
    for (int i=0; i<10; i++){
        if (v[i] > maior){
           maior = v[i];
           pos = i;
        }
    }
    printf ("o maior valor do vetor é %d.\nSua posicao é %d", maior, pos);
}
