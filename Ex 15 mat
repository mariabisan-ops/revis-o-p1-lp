#include <stdio.h>

int main(){
  char m[5][10], g[10];
  int r[5] ={0,0,0,0,0};
  for (int i=0; i<5; i++){
    for (int j=0; j<10; j++){
      printf ("digite a resposta: ");
      scanf (" %c", &m[i][j]);
    }
  }

  for (int i=0; i<10; i++){
    printf ("digite a resposta da questao: ");
    scanf (" %c", &g[i]);
  }

  for (int i=0; i<5; i++){
    for (int j=0; j<10; j++){
      if (m[i][j] == g[j]){
        r[i] ++;
      }
    }
  }

  printf ("pontuaçoes :\n");
  for (int i =0; i<5; i++){
    printf ("%d\t", r[i]);
  }
}
