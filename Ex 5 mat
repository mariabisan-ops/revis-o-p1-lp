#include <stdio.h>

int main(){
    int m[5][5], x, l, c, cont =0;
    for (int i=0; i<5; i++){
        for (int j=0; j<5; j++){
            printf ("digite um valor: ");
            scanf ("%d", &m[i][j]);
        }
    }
    printf ("digite o valor a ser buscado: ");
    scanf ("%d", &x);

    for (int i=0; i<5; i++){
        for (int j=0; j<5; j++){
            if (m[i][j] == x){
               cont ++;
               l=i;
               c=j;
            }
        }
    }
    if (cont ==0){
        printf ("valor nao encontrado");
    }
    else {
        printf ("o valor esta na linha %d e coluna %d", l,c);
    }
}
