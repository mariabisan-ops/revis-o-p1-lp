#include <stdio.h>

int main (){
    int m[4][4], maior, l, c;
    for (int i=0; i<4; i++){
        for (int j =0; j<4; j++){
            printf ("digite um valor: ");
            scanf ("%d", &m[i][j]);
        }
    }
    maior = m[0][0];
    l = 0;
    c = 0;

    for (int i=0; i<4; i++){
        for (int j=0; j<4; j++){
            if (m[i][j] > maior){
               maior = m[i][j];
               l = i;
               c = j;
            }
        }
    }
    printf ("matriz:\n");
    for (int i=0; i<4; i++){
        for (int j=0; j<4; j++){
            printf ("%d\t", m[i][j]);
        }
        printf ("\n");
    }
    printf ("\n omaior valor esta na linha %d e na coluna %d", l, c);
}
