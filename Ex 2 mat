#include <stdio.h>

int main (){
    int m[5][5];
    for (int i=0; i<5; i++){
        for (int j=0; j<5; j++){
            if (i==j){
               m[i][j] = 1;
            }
            if (i!=j) {
               m[i][j] = 0;
            }
        }
    }

    for (int i=0; i<5; i++){
        for (int j=0; j<5; j++){
            printf ("%d\t", m[i][j]);
        }
        printf ("\n");
    }
}
