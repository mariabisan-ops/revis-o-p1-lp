#include <stdio.h>

int main(){
  float m[3][6];
  float soma1=0, soma2=0, media;
  int cont=0;
  for (int i=0; i<3; i++){
    for(int j=0; j<6; j++){
      printf ("digite um valor: ");
      scanf ("%f", &m[i][j]);
    }
  }
  for (int i =0; i<3; i++){
    for (int j=1; j<6; j+=2){
      soma1 = soma1 + m[i][j];
    }
  }
  for(i=0; i<3; i++){
    for(int j=0; j<6; j++){
      soma2= m[i][1] + m[i][3];
      cont++;
    }
  }
  media = soma2/cont;

  for (int i=0; i<3; i++){
    for (int j=0; j<6; j++){
      m[i][5] = m[i][0] + m[i][1];
    }
  }
  printf ("soma dos elementos das colunas impares: %f", soma1);
  printf ("\nmedia aritmetica das colunas 2 e 4: %.2f", media);
  printf ("matriz modificada:\n");
  for (int i=0; i<3; i++){
    for (int j=0; j<6; j++){
      printf ("%f\t", m[i][j]);
    }
    printf ("\n");
  }
}
